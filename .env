# Gmail SMTP Configuration for SmartAttend
# =======================================
# 1. Enable 2-Step Verification in your Google Account Settings.
# 2. Go to App Passwords page, select "Other", name it "SmartAttend", and copy the 16-character code.
# 3. Fill in your Gmail address and the 16-character app password below.

SMTP_USER=your_email@gmail.com
SMTP_PASS=abcdefghijklmnop
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
